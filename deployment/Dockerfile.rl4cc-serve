FROM python:3.12.3-slim

# ------------------------------------------------------------------
# Environment
# ------------------------------------------------------------------
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
# -- RL4CC installation
ENV RL4CC_URL=https://github.com/FFede0/RL4CC.git
ENV RL4CC_RAW_URL=https://raw.githubusercontent.com/FFede0/RL4CC
ENV RL4CC_TAG=test_ray2.40.0
# -- runtime configuration
ENV CHECKPOINT_DIR=/app/checkpoints
ENV CONFIGURATION_FILE=/app/config/config.json
ENV LOG_FILE_BASE=/app/logs/rl4cc
# -- bootstrap modules (comma-separated, optional)
ENV APP_BOOTSTRAP_MODULES=""

# ------------------------------------------------------------------
# System dependencies
# ------------------------------------------------------------------
RUN apt-get update && apt-get install -y \
    build-essential \
    gcc \
    g++ \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------------
# Create non-root user
# ------------------------------------------------------------------
RUN useradd -m appuser

# ------------------------------------------------------------------
# Working directory
# ------------------------------------------------------------------
WORKDIR /app

# ------------------------------------------------------------------
# Install dependencies
# ------------------------------------------------------------------
RUN pip install --upgrade pip
RUN pip install \
    numpy==2.3.0 \
    ray[rllib]==2.40.0 \
    pandas \
    fastapi \
    uvicorn \
    pydantic \
    gymnasium \
    cloudpickle

# ------------------------------------------------------------------
# Install RL4CC from Git
# ------------------------------------------------------------------
RUN pip install git+${RL4CC_URL}@${RL4CC_TAG}
RUN curl -L \
    ${RL4CC_RAW_URL}/${RL4CC_TAG}/deployment/rl4cc-serve.sh \
    -o /app/rl4cc-serve.sh

# ------------------------------------------------------------------
# Create directories expected by env variables
# ------------------------------------------------------------------
RUN mkdir -p /app/checkpoints /app/config /app/logs

# ------------------------------------------------------------------
# Copy additional files from context (and install modules if required)
# ------------------------------------------------------------------
COPY . /app
RUN if [ -f /app/requirements.txt ]; then \
    echo "Installing additional Python dependencies from requirements.txt"; \
    pip install -r /app/requirements.txt; \
else \
    echo "No additional requirements.txt found"; \
fi

# ------------------------------------------------------------------
# Set ownership and change user
# ------------------------------------------------------------------
ENV PYTHONPATH=/app
RUN chown -R appuser:appuser /app
USER appuser

# ------------------------------------------------------------------
# Expose port
# ------------------------------------------------------------------
EXPOSE 8000

# ------------------------------------------------------------------
# Run FastAPI app
# ------------------------------------------------------------------
RUN chmod +x rl4cc-serve.sh
ENTRYPOINT ["./rl4cc-serve.sh"]
